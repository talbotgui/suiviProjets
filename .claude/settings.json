{
  "telemetry": "off",
  "permissions": {
    "deny": [
      "Bash(git *)",
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(ssh *)",
      "Read(*.pem)",
      "Grep(*.pem)",
      "Read(*.key)",
      "Grep(*.key)"
    ],
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.npmjs.com)",
      "WebFetch(domain:tauri.app)",
      "WebSearch",
      "WebFetch(domain:aifluencyframework.org)"
    ]
  }
}
