{
  "telemetry": "off",
  "permissions": {
    "deny": [
      "Bash(git *)",
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(ssh *)",
      "Read(*.pem)",
      "Grep(*.pem)",
      "Read(*.key)",
      "Grep(*.key)",
      "Read(*.sqm)",
      "Grep(*.sqm)"
    ],
    "allow": [
      "Bash(cargo check *)",
      "Bash(cargo fmt *)",
      "Bash(cargo test *)",
      "Bash(npx eslint *)",
      "Bash(npx jest *)",
      "Bash(npx tsc *)",
      "Bash(npx prettier *)",
      "Bash(npm run test *)",
      "Bash(npm run test:coverage*)",
      "Bash(cargo clippy *)",
      "WebFetch(domain:aifluencyframework.org)",
      "WebFetch(domain:docs.npmjs.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:tauri.app)",
      "WebSearch"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/formater-et-analyser.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/journaliser-prompt.sh\""
          }
        ]
      }
    ]
  }
}
