# Fichier généré avec l'assistance de l'IA (Claude Code), conformément à la mention d'origine requise par
# .claude/rules/01-usage-ia-et-conventions.md.
#
# Gabarit des variables d'environnement locales du poste développeur (cf. docs/02_documentation/17_posteDeveloppeur.md#variables-denvironnement).
# Copier ce fichier en ".env.local" (jamais committé, cf. .gitignore) et renseigner les valeurs nécessaires.
# Aucune valeur réelle ne doit figurer dans ce gabarit ; ne jamais committer un ".env.local" rempli.

# Verbosité des journaux techniques du cœur natif en développement (ex. debug, info, warn).
# Absence de valeur = niveau par défaut de l'application.
RUST_LOG=

# URL et jeton d'une instance GitLab réelle, utilisés exclusivement par les tests d'intégration hors CI
# (cf. docs/02_documentation/16_normesTests.md#tests-dintégration-hors-intégration-continue-contre-des-instances-réelles).
# Ne jamais renseigner un jeton réel dans un fichier committé.
SQM_TEST_GITLAB_URL=
SQM_TEST_GITLAB_TOKEN=

# URL et jeton d'une instance Sonar réelle, mêmes modalités que ci-dessus.
SQM_TEST_SONAR_URL=
SQM_TEST_SONAR_TOKEN=

# Configuration proxy respectée par le client HTTP du cœur natif (reqwest), utile si le poste de développement
# est lui-même derrière un proxy d'entreprise.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=

# Clé de signature et mot de passe associé, nécessaires uniquement pour tester localement un build signé du
# updater Tauri. Optionnelles en développement courant.
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
